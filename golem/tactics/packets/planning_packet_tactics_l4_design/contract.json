{
  "data_contract": {
    "state_shape": {
      "turn": "number",
      "status": "string ('ACTIVE' | 'VICTORY' | 'DEFEAT' | 'FINISHED')",
      "hero": {
        "hp": "number",
        "atk": "number",
        "pos": "[number, number]",
        "mana": "number",
        "anomaly_dmg": "number",
        "unit_type": "string"
      },
      "enemies": [
        {
          "id": "number",
          "hp": "number",
          "initial_hp": "number",
          "atk": "number",
          "pos": "[number, number]",
          "unit_type": "string"
        }
      ],
      "terrain": {
        "x,y": "string"
      },
      "actionList": [
        {
          "type": "string ('move' | 'attack' | 'ranged_attack' | 'anomaly_attack')",
          "dir": "[number, number]",
          "target": "number"
        }
      ]
    },
    "rules": [
      "Move: Fails if x<0, x>9, y<0, y>9, target is 'Wall', or target is occupied by enemy with hp > 0.",
      "Attack: Manhattan distance 1. Enemy takes (hero.atk - (Hardened ? 1 : 0)) * (Glass ? 2 : 1). Hero takes enemy.atk (Mana-Shield).",
      "Ranged Attack: Manhattan distance 2-3. Enemy takes hero.atk * (Glass ? 2 : 1). Hero takes 0 damage.",
      "Anomaly Attack: Manhattan distance 1-3. Enemy takes (hero.anomaly_dmg * (hero_on_conductive && target_ruptured ? 2 : 1)) * (Glass ? 2 : 1). Hero takes 0 damage. If target is Resonant, hero takes 1 damage to Mana-Shield.",
      "Victory: All enemies hp <= 0.",
      "Defeat: hero.hp <= 0 (priority over Victory)."
    ]
  },
  "interface_contract": {
    "entry": "main.js",
    "files": [
      {
        "path": "main.js",
        "exports": [],
        "imports": [
          "src/engine.js"
        ]
      },
      {
        "path": "src/engine.js",
        "exports": [
          "processSimulation"
        ],
        "imports": []
      }
    ]
  }
}