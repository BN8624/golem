{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene.schema.json",
  "title": "Forge scene contract",
  "type": "object",
  "required": [
    "id",
    "event_id",
    "sequence",
    "objective",
    "previous_scene_id",
    "start_state",
    "end_state",
    "owns",
    "consumes_setups",
    "target_chars"
  ],
  "properties": {
    "id": {"pattern": "^V[1-5]-E[0-9]{2}-S[0-9]{2}$", "type": "string"},
    "event_id": {"pattern": "^V[1-5]-E[0-9]{2}$", "type": "string"},
    "sequence": {"minimum": 1, "type": "integer"},
    "objective": {"type": "string", "minLength": 1},
    "previous_scene_id": {"type": ["string", "null"]},
    "start_state": {"type": "object"},
    "end_state": {"type": "object"},
    "owns": {
      "type": "object",
      "required": ["changes", "setups", "payoffs"],
      "properties": {
        "changes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "setups": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "payoffs": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "consumes_setups": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string"}
    },
    "target_chars": {"minimum": 500, "type": "integer"}
  },
  "additionalProperties": false
}
