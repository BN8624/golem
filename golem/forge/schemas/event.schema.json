{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event.schema.json",
  "title": "Forge event contract",
  "type": "object",
  "required": ["id", "volume_id", "sequence", "objective", "start_state", "end_state", "scene_ids"],
  "properties": {
    "id": {"pattern": "^V[1-5]-E[0-9]{2}$", "type": "string"},
    "volume_id": {"pattern": "^V[1-5]$", "type": "string"},
    "sequence": {"minimum": 1, "type": "integer"},
    "objective": {"type": "string", "minLength": 1},
    "start_state": {"type": "object"},
    "end_state": {"type": "object"},
    "scene_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"pattern": "^V[1-5]-E[0-9]{2}-S[0-9]{2}$", "type": "string"}
    }
  },
  "additionalProperties": false
}
