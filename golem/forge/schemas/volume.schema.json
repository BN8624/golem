{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "volume.schema.json",
  "title": "Forge volume contract",
  "type": "object",
  "required": ["id", "index", "series_id", "title", "objective", "start_state", "end_state", "event_ids"],
  "properties": {
    "id": {"pattern": "^V[1-5]$", "type": "string"},
    "index": {"minimum": 1, "maximum": 5, "type": "integer"},
    "series_id": {"const": "SERIES"},
    "title": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "start_state": {"type": "object"},
    "end_state": {"type": "object"},
    "event_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"pattern": "^V[1-5]-E[0-9]{2}$", "type": "string"}
    }
  },
  "additionalProperties": false
}
