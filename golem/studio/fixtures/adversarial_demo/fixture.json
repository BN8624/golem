      { "id": "ACC-003", "category": "boundary", "input": { "initialState": { "energy": 999 }, "actions": [{ "action": "WAIT" }] }, "covers_reqs": ["RULE-05"], "expected": { "turn": 1, "energy": 1000, "productionRate": 1, "gameStatus": "WON" }, "oracle_risk": { "risk": false, "reason": "" } },
